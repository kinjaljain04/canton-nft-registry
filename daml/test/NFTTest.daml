module NFTTest where

import Daml.Script
import DA.Assert
import DA.Optional (isNone)

import NFT

-- | A Daml Script test suite for the complete NFT lifecycle.
-- This test covers:
-- 1. Setup of minter roles and royalty policies.
-- 2. Minting a new NFT.
-- 3. Listing the NFT for a fixed price.
-- 4. A buyer purchasing the NFT from the listing, triggering payment and royalty distribution.
-- 5. A different buyer making an offer on the NFT.
-- 6. The current owner accepting the offer, again triggering payment and royalty distribution.
-- 7. The final owner performing a direct transfer, which also enforces royalties.
nftLifecycleTest = script do
  -- === Parties Setup ===
  minter <- allocatePartyWithHint "Minter" (PartyIdHint "minter")
  artist <- allocatePartyWithHint "Artist" (PartyIdHint "artist")
  gallery <- allocatePartyWithHint "Gallery" (PartyIdHint "gallery")
  alice <- allocatePartyWithHint "Alice" (PartyIdHint "alice")
  bob <- allocatePartyWithHint "Bob" (PartyIdHint "bob")
  charlie <- allocatePartyWithHint "Charlie" (PartyIdHint "charlie")

  -- === 1. Roles and Policies Setup ===
  -- The minter is given a role contract allowing them to mint NFTs.
  -- The artist creates a royalty policy for their collection.
  minterRoleCid <- submit minter do
    createCmd MinterRole with minter, observers = [gallery]

  royaltyPolicyCid <- submit artist do
    createCmd RoyaltyPolicy with
      issuer = artist
      recipient = artist
      rate = 0.05 -- 5%
      observers = [gallery, minter]

  -- === 2. Minting ===
  -- The minter creates a new NFT and assigns it to the initial owner, Alice.
  let
    contentHash = "a43a655755e1b52a425339c2f63f538ec9103de61474a05584b421c97a5a8e63"
    metadataUrl = "https://example.com/nft/1.json"

  nftCid_alice <- submit minter do
    exerciseCmd minterRoleCid Mint with
      owner = alice
      royaltyPolicyCid
      contentHash
      metadataUrl
      observers = [gallery]

  -- Verification: Check that Alice owns the newly minted NFT.
  (nftCid, nft) <- queryContractId alice nftCid_alice
  debug $ "1. Minted NFT " <> show nftCid <> " for Alice"
  assert (nft.owner == alice)
  assert (nft.minter == minter)
  assert (nft.royaltyPolicyCid == royaltyPolicyCid)
  assert (nft.contentHash == contentHash)

  -- === 3. Fixed Price Sale ===
  -- Alice lists her NFT for sale at a fixed price.
  let salePrice1 = 100.0
  listingCid <- submit alice do
    createCmd FixedPriceListing with
      seller = alice
      nftCid
      price = salePrice1
      observers = [gallery, bob]
  debug $ "2. Alice listed NFT for " <> show salePrice1

  -- Bob purchases the NFT from the listing.
  (newNftCid_bob, (sellerPaymentCid1, royaltyPaymentCid1)) <- submit bob do
    exerciseCmd listingCid Purchase with buyer = bob
  debug "3. Bob purchased NFT from listing"

  -- Verification:
  -- a) The listing contract should be archived.
  listingQuery <- queryContractId bob listingCid
  assertMsg "FixedPriceListing should be archived after purchase" (isNone listingQuery)

  -- b) A new NFT contract should exist, owned by Bob.
  (_, nft_bob) <- queryContractId bob newNftCid_bob
  assert (nft_bob.owner == bob)
  assert (nft_bob.minter == minter)

  -- c) A payment obligation should be created for the seller (Alice).
  (_, sellerPayment1) <- queryContractId alice sellerPaymentCid1
  let expectedSellerAmount1 = salePrice1 * (1.0 - 0.05)
  assert (sellerPayment1.payer == bob)
  assert (sellerPayment1.receiver == alice)
  assert (sellerPayment1.amount == expectedSellerAmount1)
  debug $ "Seller (Alice) payment obligation created for " <> show sellerPayment1.amount

  -- d) A royalty payment obligation should be created for the artist.
  (_, royaltyPayment1) <- queryContractId artist royaltyPaymentCid1
  let expectedRoyaltyAmount1 = salePrice1 * 0.05
  assert (royaltyPayment1.payer == bob)
  assert (royaltyPayment1.receiver == artist)
  assert (royaltyPayment1.amount == expectedRoyaltyAmount1)
  debug $ "Artist royalty obligation created for " <> show royaltyPayment1.amount

  -- === 4. Offer and Accept Flow ===
  -- Charlie makes an offer on the NFT now owned by Bob.
  let offerPrice = 120.0
  offerCid <- submit charlie do
    createCmd Offer with
      buyer = charlie
      nftCid = newNftCid_bob
      price = offerPrice
      observers = [gallery, bob]
  debug $ "4. Charlie made an offer of " <> show offerPrice <> " for Bob's NFT"

  -- Bob accepts Charlie's offer.
  (newNftCid_charlie, (sellerPaymentCid2, royaltyPaymentCid2)) <- submit bob do
    exerciseCmd newNftCid_bob AcceptOffer with offerCid
  debug "5. Bob accepted Charlie's offer"

  -- Verification:
  -- a) The offer contract should be archived.
  offerQuery <- queryContractId charlie offerCid
  assertMsg "Offer should be archived after being accepted" (isNone offerQuery)

  -- b) A new NFT contract should exist, owned by Charlie.
  (_, nft_charlie) <- queryContractId charlie newNftCid_charlie
  assert (nft_charlie.owner == charlie)

  -- c) A payment obligation should be created for the seller (Bob).
  (_, sellerPayment2) <- queryContractId bob sellerPaymentCid2
  let expectedSellerAmount2 = offerPrice * (1.0 - 0.05)
  assert (sellerPayment2.payer == charlie)
  assert (sellerPayment2.receiver == bob)
  assert (sellerPayment2.amount == expectedSellerAmount2)
  debug $ "Seller (Bob) payment obligation created for " <> show sellerPayment2.amount

  -- d) A royalty payment obligation should be created for the artist.
  (_, royaltyPayment2) <- queryContractId artist royaltyPaymentCid2
  let expectedRoyaltyAmount2 = offerPrice * 0.05
  assert (royaltyPayment2.payer == charlie)
  assert (royaltyPayment2.receiver == artist)
  assert (royaltyPayment2.amount == expectedRoyaltyAmount2)
  debug $ "Artist royalty obligation created for " <> show royaltyPayment2.amount

  -- === 5. Direct Transfer with Royalty ===
  -- Charlie transfers the NFT directly to Alice, specifying a sale price for royalty calculation.
  let salePrice2 = 50.0
  (finalNftCid_alice, (sellerPaymentCid3, royaltyPaymentCid3)) <- submit charlie do
    exerciseCmd newNftCid_charlie Transfer with
      newOwner = alice
      salePrice = salePrice2
  debug $ "6. Charlie transferred NFT to Alice for a declared value of " <> show salePrice2

  -- Verification:
  -- a) A new NFT contract should exist, owned by Alice again.
  (_, finalNft_alice) <- queryContractId alice finalNftCid_alice
  assert (finalNft_alice.owner == alice)

  -- b) A payment obligation should be created for the seller (Charlie).
  (_, sellerPayment3) <- queryContractId charlie sellerPaymentCid3
  let expectedSellerAmount3 = salePrice2 * (1.0 - 0.05)
  assert (sellerPayment3.payer == alice)
  assert (sellerPayment3.receiver == charlie)
  assert (sellerPayment3.amount == expectedSellerAmount3)
  debug $ "Seller (Charlie) payment obligation created for " <> show sellerPayment3.amount

  -- c) A royalty payment obligation should be created for the artist.
  (_, royaltyPayment3) <- queryContractId artist royaltyPaymentCid3
  let expectedRoyaltyAmount3 = salePrice2 * 0.05
  assert (royaltyPayment3.payer == alice)
  assert (royaltyPayment3.receiver == artist)
  assert (royaltyPayment3.amount == expectedRoyaltyAmount3)
  debug $ "Artist royalty obligation created for " <> show royaltyPayment3.amount

  debug "NFT lifecycle test completed successfully."
  return ()